// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  MANAGER
  LOAN_EXECUTIVE
  CONTENT_MANAGER
  VIEWER
}

model AdminUser {
  id           String     @id @default(uuid())
  email        String     @unique
  passwordHash String
  name         String
  role         Role       @default(VIEWER)
  status       String     @default("ACTIVE") // ACTIVE, INACTIVE
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  leads        Lead[]     @relation("ExecutiveLeads")
  auditLogs    AuditLog[]

  @@index([email])
}

model Lead {
  id                 String              @id @default(uuid())
  leadNumber         String              @unique @default("") // WF-YYYYMMDD-000001
  name               String
  phone              String
  email              String
  city               String
  employmentType     String              // SALARIED, SELF_EMPLOYED, BUSINESS_OWNER, MSME, PROFESSIONAL
  monthlyIncome      Float
  loanType           String              // PERSONAL, BUSINESS, HOME, LAP, CREDIT_CARD
  loanAmount         Float
  status             String              @default("NEW") // NEW, CONTACTED, IN_PROGRESS, APPROVED, REJECTED, ARCHIVED
  priority           String              @default("MEDIUM") // HIGH, MEDIUM, LOW
  tags               String              @default("") // Comma separated tags
  remarks            String              @default("")
  reminderDate       DateTime?
  nextFollowupDate   DateTime?
  source             String              @default("WEBSITE") // WEBSITE, WHATSAPP, REFERRAL, CALCULATOR, etc.
  campaign           String?
  utmSource          String?
  utmMedium          String?
  utmCampaign        String?
  // WhatsApp CRM Tracking
  whatsappClicked    Boolean             @default(false)
  whatsappClickedAt  DateTime?
  // Traffic Source Metadata
  ipAddress          String              @default("")
  browserInfo        String              @default("")
  landingPage        String              @default("")
  assignedToId       String?
  assignedTo         AdminUser?          @relation("ExecutiveLeads", fields: [assignedToId], references: [id])
  notes              LeadNote[]
  statusHistory      LeadStatusHistory[]
  isDeleted          Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@index([status])
  @@index([loanType])
  @@index([assignedToId])
  @@index([createdAt])
  @@index([phone])
  @@index([leadNumber])
  @@index([source])
}

model LeadNote {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  authorName String
  content    String
  createdAt  DateTime @default(now())

  @@index([leadId])
}

model LeadStatusHistory {
  id         String   @id @default(uuid())
  leadId     String
  lead       Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  oldStatus  String
  newStatus  String
  changedBy  String
  changedAt  DateTime @default(now())

  @@index([leadId])
}

model BlogPost {
  id             String    @id @default(uuid())
  title          String
  slug           String    @unique
  content        String    @db.Text
  summary        String    @db.Text
  featuredImage  String    @default("")
  status         String    @default("DRAFT") // DRAFT, PUBLISHED, SCHEDULED
  publishedAt    DateTime?
  authorName     String    @default("Whitestone Team")
  category       String    @default("Finance")
  tags           String    @default("")
  seoTitle       String?
  seoDescription String?
  isDeleted      Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([category])
}

model FAQ {
  id        String   @id @default(uuid())
  question  String
  answer    String   @db.Text
  category  String   @default("General") // General, Eligibility, Documentation, Processing, Calculators
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Testimonial {
  id          String   @id @default(uuid())
  name        String
  designation String
  company     String
  rating      Int      @default(5)
  quote       String   @db.Text
  imageUrl    String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WebSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model AuditLog {
  id          String     @id @default(uuid())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: SetNull)
  username    String     @default("System")
  action      String
  details     String     @db.Text
  createdAt   DateTime   @default(now())

  @@index([adminUserId])
  @@index([createdAt])
}
